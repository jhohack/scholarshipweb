{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0",
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "^/assets/(.*)$",
      "dest": "/public/assets/$1"
    },
    {
      "src": "^/uploads/(.*)$",
      "dest": "/public/uploads/$1"
    },
    {
      "src": "^/images/(.*)$",
      "dest": "/images/$1"
    },
    {
      "src": "^/sw\\.js$",
      "dest": "/public/sw.js"
    },
    {
      "src": "^/manifest\\.json$",
      "dest": "/public/manifest.json"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
